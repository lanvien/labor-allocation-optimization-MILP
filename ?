        "import numpy as np\n",
        "import random\n",
        "\n",
        "N_RUNS = 1000\n",
        "milp_sim_costs = []\n",
        "heuristic_sim_costs = []\n",
        "\n",
        "# Lấy assignment từ kết quả trên\n",
        "milp_assign = {'P1': ['W1', 'W4'], 'P2': ['W2', 'W3', 'W5']}\n",
        "h_assign = {'P1': ['W1', 'W5', 'W3'], 'P2': ['W4', 'W2']}\n",
        "\n",
        "for _ in range(N_RUNS):\n",
        "    # 1. Tạo nhiễu cho Skill: Mỗi thợ có thể mệt hoặc hăng hái (+-2)\n",
        "    daily_skills = {w: max(0, skills[w] + random.randint(-5, 5)) for w in workers}\n",
        "\n",
        "    # 2. Tính hậu quả cho MILP\n",
        "    m_cost = 126 # Base cost (travel)\n",
        "    m_gap_penalty = 0\n",
        "    for p in projects:\n",
        "        s_total = sum(daily_skills[w] for w in milp_assign[p])\n",
        "        m_gap_penalty += max(0, requirements[p] - s_total) * alpha\n",
        "    milp_sim_costs.append(m_cost + m_gap_penalty)\n",
        "\n",
        "    # 3. Tính hậu quả cho Heuristic\n",
        "    h_cost = 138 # Base cost (travel)\n",
        "    h_gap_penalty = 0\n",
        "    for p in projects:\n",
        "        s_total = sum(daily_skills[w] for w in h_assign[p])\n",
        "        h_gap_penalty += max(0, requirements[p] - s_total) * alpha\n",
        "    heuristic_sim_costs.append(h_cost + h_gap_penalty)\n",
        "\n",
        "print(f\"--- DAY 5: MONTE CARLO (1000 RUNS) ---\")\n",
        "print(f\"MILP - Average Cost: {np.mean(milp_sim_costs):.2f} | Std Dev: {np.std(milp_sim_costs):.2f}\")\n",
        "print(f\"Heuristic - Average Cost: {np.mean(heuristic_sim_costs):.2f} | Std Dev: {np.std(heuristic_sim_costs):.2f}\")"
