        "def run_heuristic_day4(workers, projects, skills, requirements, costs, alpha):\n",
        "    rem_req = requirements.copy()\n",
        "    assigned = {p: [] for p in projects}\n",
        "    # Sắp xếp thợ giỏi nhất lên đầu\n",
        "    sorted_workers = sorted(workers, key=lambda w: skills[w], reverse=True)\n",
        "\n",
        "    total_travel = 0\n",
        "    for w in sorted_workers:\n",
        "        # Thợ giỏi nhất sẽ nhảy vào dự án đang \"đói\" kỹ năng nhất\n",
        "        target_p = max(rem_req, key=rem_req.get)\n",
        "        assigned[target_p].append(w)\n",
        "        total_travel += costs[w][target_p]\n",
        "        rem_req[target_p] -= skills[w]\n",
        "\n",
        "    # Tính tiền phạt nếu sau khi chia xong vẫn thiếu\n",
        "    total_penalty = sum([max(0, rem_req[p]) * alpha for p in projects])\n",
        "    return total_travel + total_penalty, assigned\n",
        "\n",
        "h_obj, h_assigned = run_heuristic_day4(workers, projects, skills, requirements, costs, alpha)\n",
        "\n",
        "print(f\"--- DAY 4: HEURISTIC RESULT ---\")\n",
        "print(f\"Tổng Objective (H): {h_obj}\")\n",
        "for p in projects:\n",
        "    print(f\"Dự án {p}: {h_assigned[p]}\")"
      ],
