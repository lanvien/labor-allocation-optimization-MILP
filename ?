        "import pulp\n",
        "\n",
        "# 1. Khởi tạo dữ liệu Cố định (Fixed Data)\n",
        "workers = ['W1', 'W2', 'W3', 'W4', 'W5']\n",
        "projects = ['P1', 'P2']\n",
        "costs = {\n",
        "    'W1': {'P1': 14, 'P2': 50},\n",
        "    'W2': {'P1': 30, 'P2': 26},\n",
        "    'W3': {'P1': 40, 'P2': 26},\n",
        "    'W4': {'P1': 15, 'P2': 35},\n",
        "    'W5': {'P1': 23, 'P2': 45}\n",
        "}\n",
        "skills = {'W1': 8, 'W2': 5, 'W3': 4, 'W4': 7, 'W5': 6}\n",
        "requirements = {'P1': 15, 'P2': 12}\n",
        "alpha = 100 # Trọng số phạt nếu thiếu kỹ năng\n",
        "\n",
        "# 2. Khai báo bài toán\n",
        "prob = pulp.LpProblem(\"Day3_MILP_Optimization\", pulp.LpMinimize)\n",
        "\n",
        "# Biến quyết định: x[i][j] là chọn thợ i cho dự án j\n",
        "x = pulp.LpVariable.dicts(\"x\", (workers, projects), cat='Binary')\n",
        "\n",
        "# Biến bù (Slack): g[j] là lượng kỹ năng còn thiếu ở dự án j\n",
        "g = pulp.LpVariable.dicts(\"g\", projects, lowBound=0, cat='Continuous')\n",
        "\n",
        "# 3. Hàm mục tiêu: Min (Chi phí đi lại + Chi phí phạt thiếu hụt)\n",
        "prob += pulp.lpSum([costs[w][p] * x[w][p] for w in workers for p in projects]) + \\\n",
        "        pulp.lpSum([alpha * g[p] for p in projects])\n",
        "\n",
        "# 4. Ràng buộc\n",
        "for w in workers:\n",
        "    prob += pulp.lpSum([x[w][p] for p in projects]) <= 1 # Mỗi thợ 1 việc\n",
        "\n",
        "for p in projects:\n",
        "    # Tổng kỹ năng + phần thiếu hụt >= Yêu cầu\n",
        "    prob += pulp.lpSum([skills[w] * x[w][p] for w in workers]) + g[p] >= requirements[p]\n",
        "\n",
        "# 5. Giải bài toán\n",
        "prob.solve()\n",
        "\n",
        "# In kết quả chuẩn để lưu vào Paper\n",
        "milp_obj = pulp.value(prob.objective)\n",
        "print(f\"--- DAY 3: MILP RESULT ---\")\n",
        "print(f\"Trạng thái: {pulp.LpStatus[prob.status]}\")\n",
        "print(f\"Tổng Objective (Z): {milp_obj}\")\n",
        "\n",
        "for p in projects:\n",
        "    assigned = [w for w in workers if pulp.value(x[w][p]) == 1]\n",
        "    print(f\"Dự án {p}: {assigned} | Thiếu (g): {pulp.value(g[p])}\")"
