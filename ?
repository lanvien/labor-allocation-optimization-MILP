      "source": [
        "import pulp\n",
        "\n",
        "# 1. Dữ liệu có thêm Skill\n",
        "workers = ['W1', 'W2', 'W3', 'W4', 'W5']\n",
        "projects = ['P1', 'P2']\n",
        "costs = {'W1': {'P1': 14, 'P2': 50}, 'W2': {'P1': 30, 'P2': 26},\n",
        "         'W3': {'P1': 40, 'P2': 26}, 'W4': {'P1': 15, 'P2': 35},\n",
        "         'W5': {'P1': 23, 'P2': 45}}\n",
        "skills = {'W1': 8, 'W2': 5, 'W3': 4, 'W4': 7, 'W5': 6}\n",
        "requirements = {'P1': 15, 'P2': 12} # Tổng skill cần thiết\n",
        "alpha = 100 # Hình phạt cho mỗi đơn vị skill bị thiếu (Penalty weight)\n",
        "\n",
        "# 2. Khai báo bài toán\n",
        "prob = pulp.LpProblem(\"Optimization_with_Slack\", pulp.LpMinimize)\n",
        "x = pulp.LpVariable.dicts(\"x\", (workers, projects), cat='Binary')\n",
        "g = pulp.LpVariable.dicts(\"g\", projects, lowBound=0, cat='Continuous') # Slack variable\n",
        "\n",
        "# 3. Objective Function: Min (Travel Cost + Penalty for Skill Gap)\n",
        "prob += pulp.lpSum([costs[w][p] * x[w][p] for w in workers for p in projects]) + \\\n",
        "        pulp.lpSum([alpha * g[p] for p in projects])\n",
        "\n",
        "# 4. Constraints\n",
        "for w in workers:\n",
        "    prob += pulp.lpSum([x[w][p] for p in projects]) <= 1\n",
        "\n",
        "# Ép tổng skill + phần thiếu (g) phải bằng yêu cầu\n",
        "for p in projects:\n",
        "    prob += pulp.lpSum([skills[w] * x[w][p] for w in workers]) + g[p] >= requirements[p]\n",
        "\n",
        "# 5. Solve\n",
        "prob.solve()\n",
        "\n",
        "print(f\"Trạng thái: {pulp.LpStatus[prob.status]}\")\n",
        "print(f\"Tổng Objective (Cost + Penalty): {pulp.value(prob.objective)}\")\n",
        "\n",
        "for p in projects:\n",
        "    assigned = [w for w in workers if pulp.value(x[w][p]) == 1]\n",
        "    total_s = sum(skills[w] for w in assigned)\n",
        "    gap = pulp.value(g[p])\n",
        "    print(f\"Dự án {p}: Thợ {assigned} | Tổng Skill: {total_s}/{requirements[p]} | Thiếu (Slack): {gap}\")"
      ],
